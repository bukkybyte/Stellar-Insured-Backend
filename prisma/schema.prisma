// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Insurance is the primary product domain for this service.
// Legacy project/contribution models remain because the indexer,
// reputation, and notification workflows still depend on them.

model User {
  id              String    @id @default(cuid())
  walletAddress   String    @unique @map("wallet_address") // Public blockchain identifier
  profileData     Json?     @map("profile_data")
  reputationScore Int       @default(0) @map("reputation_score")
  trustScore      Int       @default(500) @map("trust_score")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Notification fields (encrypted at rest)
  email            String? @unique // Encrypted at rest - PII
  pushSubscription Json?   @map("push_subscription") // Encrypted at rest

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  insurancePolicies    InsurancePolicy[]
  auditLogs            AuditLog[]

  @@index([deletedAt])
  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  status       ProjectStatus @default(ACTIVE)
  ipfsHash     String?       @map("ipfs_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@index([creatorId])
  @@index([status, deadline])
  @@index([deletedAt])
  @@map("projects")
}

model Contribution {
  id              String    @id @default(cuid())
  transactionHash String    @unique @map("transaction_hash")
  investorId      String    @map("investor_id")
  investor        User      @relation(fields: [investorId], references: [id])
  projectId       String    @map("project_id")
  project         Project   @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime  @default(now())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([investorId])
  @@index([projectId])
  @@index([projectId, investorId])
  @@index([deletedAt])
  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("milestones")
}

model ReputationHistory {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  scoreChange Int       @map("score_change")
  reason      String
  timestamp   DateTime  @default(now())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([userId])
  @@index([timestamp])
  @@index([deletedAt])
  @@map("reputation_history")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("categories")
}

model InsurancePool {
  id            String                @id @default(uuid())
  name          String
  capital       Decimal               @db.Decimal(18, 2)
  lockedCapital Decimal               @default(0) @map("locked_capital") @db.Decimal(18, 2)
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  deletedAt     DateTime?             @map("deleted_at")
  policies      InsurancePolicy[]
  contracts     ReinsuranceContract[]

  @@index([deletedAt])
  @@map("insurance_pools")
}

model ReinsuranceContract {
  id            String            @id @default(uuid())
  poolId        String            @map("pool_id")
  pool          InsurancePool     @relation(fields: [poolId], references: [id])
  coverageLimit Decimal           @map("coverage_limit") @db.Decimal(18, 2)
  premiumRate   Decimal           @map("premium_rate") @db.Decimal(10, 4)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")
  policies      InsurancePolicy[]

  @@index([poolId])
  @@index([deletedAt])
  @@map("reinsurance_contracts")
}

model InsurancePolicy {
  id             String               @id @default(uuid())
  userId         String               @map("user_id")
  user           User                 @relation(fields: [userId], references: [id])
  poolId         String               @map("pool_id")
  pool           InsurancePool        @relation(fields: [poolId], references: [id])
  contractId     String?              @map("contract_id")
  contract       ReinsuranceContract? @relation(fields: [contractId], references: [id])
  riskType       RiskType
  premium        Decimal              @db.Decimal(18, 2)
  coverageAmount Decimal              @map("coverage_amount") @db.Decimal(18, 2)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")
  claims         Claim[]

  @@index([userId])
  @@index([poolId])
  @@index([contractId])
  @@index([riskType])
  @@index([deletedAt])
  @@map("insurance_policies")
}

model Claim {
  id           String          @id @default(uuid())
  policyId     String          @map("policy_id")
  policy       InsurancePolicy @relation(fields: [policyId], references: [id])
  claimAmount  Decimal         @map("claim_amount") @db.Decimal(18, 2)
  status       ClaimStatus     @default(PENDING)
  payoutAmount Decimal?        @map("payout_amount") @db.Decimal(18, 2)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@index([policyId])
  @@index([status])
  @@index([deletedAt])
  @@map("claims")
}

model AuditLog {
  id              String      @id @default(uuid())
  userId          String?     @map("user_id")
  user            User?       @relation(fields: [userId], references: [id])
  action          AuditAction
  entityType      String      @map("entity_type")
  entityId        String      @map("entity_id")
  beforeState     Json?       @map("before_state")
  afterState      Json?       @map("after_state")
  ipAddress       String?     @map("ip_address")
  userAgent       String?     @map("user_agent")
  transactionHash String?     @map("transaction_hash")
  reason          String?
  timestamp       DateTime    @default(now())
  createdAt       DateTime    @default(now()) @map("created_at")
  deletedAt       DateTime?   @map("deleted_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([deletedAt])
  @@map("audit_logs")
}

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  PAYOUT
  PURCHASE
  ADD_CAPITAL
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String    @id @default(cuid())
  network        String    @unique
  lastLedgerSeq  Int       @map("last_ledger_seq")
  lastLedgerHash String?   @map("last_ledger_hash")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String    @id @default(cuid())
  eventId         String    @unique @map("event_id")
  network         String
  ledgerSeq       Int       @map("ledger_seq")
  contractId      String    @map("contract_id")
  eventType       String    @map("event_type")
  transactionHash String    @map("transaction_hash")
  processedAt     DateTime  @default(now()) @map("processed_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@index([deletedAt])
  @@map("processed_events")
}

model IndexerLog {
  id        String    @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime  @default(now())
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([timestamp])
  @@index([level])
  @@index([deletedAt])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  user                User      @relation(fields: [userId], references: [id])
  emailEnabled        Boolean   @default(true) @map("email_enabled")
  pushEnabled         Boolean   @default(false) @map("push_enabled")
  notifyContributions Boolean   @default(true) @map("notify_contributions")
  notifyMilestones    Boolean   @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean   @default(true) @map("notify_deadlines")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")
  deletedAt DateTime?        @map("deleted_at")

  @@index([userId])
  @@index([userId, read, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  @@index([status])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("email_outbox")
}

model IdempotencyKey {
  id          String    @id @default(cuid())
  key         String    @unique
  method      String
  endpoint    String
  requestBody Json
  response    Json?
  status      String    @default("PENDING")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([expiresAt])
  @@index([method, endpoint])
  @@index([deletedAt])
  @@map("idempotency_keys")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}
